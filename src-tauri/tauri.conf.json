{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Heartflow",
  "version": "0.1.0",
  "identifier": "com.dajbelshaw.heartflow",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Heartflow",
        "width": 380,
        "height": 580,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: http: https: data: blob:; style-src 'self' 'unsafe-inline'; media-src 'self' http: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/tray/heart.png",
      "icons/tray/heart@2x.png"
    ],
    "category": "Music",
    "shortDescription": "Favourites shuffle player for Plex",
    "macOS": {
      "signingIdentity": null,
      "infoPlist": "Info.plist"
    }
  }
}
